{
  "html": "\n\n    <!-- VERSION HERO — TERMINAL TRANSMISSION BLOCK -->\n    <div style=\"position:relative;margin-bottom:3rem;overflow:hidden;clip-path:polygon(20px 0%,100% 0%,100% calc(100% - 20px),calc(100% - 20px) 100%,0% 100%,0% 20px);\">\n      <div style=\"position:absolute;top:0;left:0;width:20px;height:20px;border-top:2px solid var(--c-primary);border-left:2px solid var(--c-primary);opacity:.9;z-index:3;pointer-events:none;\"></div>\n      <div style=\"position:absolute;top:0;right:0;width:20px;height:20px;border-top:2px solid var(--c-accent);border-right:2px solid var(--c-accent);opacity:.9;z-index:3;pointer-events:none;\"></div>\n      <div style=\"position:absolute;bottom:0;left:0;width:20px;height:20px;border-bottom:2px solid var(--c-accent);border-left:2px solid var(--c-accent);opacity:.9;z-index:3;pointer-events:none;\"></div>\n      <div style=\"position:absolute;bottom:0;right:0;width:20px;height:20px;border-bottom:2px solid var(--c-primary);border-right:2px solid var(--c-primary);opacity:.9;z-index:3;pointer-events:none;\"></div>\n      <div style=\"border:1px solid rgba(0,245,255,.14);background:linear-gradient(135deg,rgba(0,245,255,.022) 0%,transparent 35%,rgba(0,0,0,.55) 100%);padding:3rem 2rem 2.5rem;text-align:center;position:relative;overflow:hidden;\">\n        <!-- Interior scan lines -->\n        <div style=\"position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 28px,rgba(0,245,255,.012) 28px,rgba(0,245,255,.012) 29px);pointer-events:none;\"></div>\n        <div style=\"position:absolute;left:0;right:0;height:1px;top:-1px;background:linear-gradient(90deg,transparent,var(--c-primary),var(--c-accent),var(--c-primary),transparent);animation:scanDown 5.5s linear infinite;pointer-events:none;\"></div>\n        <!-- Hex orbits in background -->\n        <div style=\"position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:320px;height:320px;border:1px dashed rgba(0,245,255,.06);border-radius:50%;animation:rSlow 45s linear infinite;pointer-events:none;\"></div>\n        <div style=\"position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:180px;height:180px;border:1px solid rgba(57,255,20,.04);border-radius:50%;animation:rSlow 28s linear infinite reverse;pointer-events:none;\"></div>\n        <div style=\"position:relative;z-index:2;\">\n          <div style=\"font-family:'Cinzel',serif;font-size:.52rem;letter-spacing:.75em;color:rgba(0,245,255,.3);margin-bottom:.8rem;animation:spSubIn .9s ease .3s both;\">⬡ INCOMING TRANSMISSION ⬡</div>\n          <div style=\"font-family:'Cinzel Decorative',cursive;font-size:clamp(2.5rem,7.5vw,5rem);color:var(--c-primary);text-shadow:0 0 30px var(--c-glow),0 0 65px rgba(0,245,255,.12),0 0 120px rgba(0,245,255,.06);letter-spacing:.07em;line-height:1;margin-bottom:.38rem;animation:sGlow 4.5s ease-in-out infinite;\">Megaverde 1.5</div>\n          <div style=\"font-family:'Cinzel',serif;font-size:clamp(.85rem,2.5vw,1.45rem);color:var(--c-accent);letter-spacing:.52em;text-shadow:0 0 14px var(--c-glow);margin-bottom:1.6rem;\">\"ONLINE\"</div>\n          <!-- Tag row -->\n          <div id=\"up-tags-row\" style=\"display:flex;align-items:center;justify-content:center;gap:.4rem;flex-wrap:wrap;margin-bottom:1.4rem;\">\n            <span style=\"font-family:'Cinzel',serif;font-size:.44rem;letter-spacing:.18em;color:rgba(57,255,20,.6);border:1px solid rgba(57,255,20,.18);padding:.14rem .5rem;background:rgba(57,255,20,.04);clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);\">Performance</span>\n            <span style=\"font-family:'Cinzel',serif;font-size:.44rem;letter-spacing:.18em;color:rgba(0,245,255,.55);border:1px solid rgba(0,245,255,.14);padding:.14rem .5rem;background:rgba(0,245,255,.03);clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);\">interaction</span>\n            <span style=\"font-family:'Cinzel',serif;font-size:.44rem;letter-spacing:.18em;color:rgba(255,140,0,.55);border:1px solid rgba(255,140,0,.16);padding:.14rem .5rem;background:rgba(255,140,0,.03);clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%);\">security</span>\n            \n            \n          </div>\n          <!-- Deployment bar -->\n          <div style=\"max-width:420px;margin:0 auto;\">\n            <div style=\"display:flex;justify-content:space-between;font-family:'Cinzel',serif;font-size:.44rem;letter-spacing:.2em;color:rgba(0,245,255,.28);margin-bottom:.32rem;\">\n              <span>DEPLOYMENT STATUS</span><span style=\"color:var(--c-accent);\">2/ 2 PACKAGES</span>\n            </div>\n            <div style=\"height:3px;background:rgba(0,245,255,.07);border-radius:2px;overflow:hidden;position:relative;\">\n              <div style=\"position:absolute;inset:0;background:linear-gradient(90deg,var(--c-primary),var(--c-accent));box-shadow:0 0 10px var(--c-glow);border-radius:2px;\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- SECTION LABEL -->\n    <div style=\"font-family:'Cinzel',serif;font-size:.52rem;letter-spacing:.42em;color:rgba(0,245,255,.32);text-transform:uppercase;margin-bottom:1.2rem;display:flex;align-items:center;gap:.6rem;\">\n      <span style=\"display:block;width:6px;height:6px;clip-path:polygon(50% 0%,93% 25%,93% 75%,50% 100%,7% 75%,7% 25%);background:var(--c-primary);box-shadow:0 0 6px var(--c-glow);\"></span>\n      DATA PACKAGES — TRANSMISSION 1.5<span style=\"flex:1;height:1px;background:linear-gradient(90deg,rgba(0,245,255,.18),transparent);display:block;\"></span>\n    </div>\n\n    <!-- UPDATE CARDS GRID -->\n    <div id=\"up-cards-grid\" style=\"display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1rem;\">\n\n      <!-- PKG 01 -->\n      \n\n      <!-- PKG 02 -->\n      \n\n      <!-- PKG 03 -->\n      \n\n      <!-- PKG 04 -->\n      <div class=\"up-tc\" style=\"--utc: #b464ff; position: relative;\">\n        <div class=\"up-tc-head\">\n          <div class=\"up-tc-icon\" style=\"color:#b464ff;border-color:rgba(180,100,255,.22);\">▶</div>\n          <div class=\"up-tc-meta\">\n            <div class=\"up-tc-title\"><span style=\"font-size: 14.08px;\">BETTER PEFORMANCE</span></div><div class=\"up-tc-title\"><span style=\"font-size: 0.5rem; letter-spacing: 0.12em;\">Removal wave</span></div>\n          </div>\n          <div class=\"up-tc-cls\" style=\"color:#b464ff;border-color:rgba(180,100,255,.25);background:rgba(180,100,255,.05);\">FIXED</div>\n        </div>\n        <div class=\"up-tc-body\">\n          <div class=\"up-tc-line\">⟡ Removed dead code</div><div class=\"up-tc-line\">⟡ Removed Lighting</div><div class=\"up-tc-line\">⟡ Removed useless features and texts</div><div class=\"up-tc-line\">⟡ Fixed the Screensaver (Still not on Mobile)</div></div><div class=\"up-tc-foot\">\n          <div class=\"up-tc-lbl\">DEPLOYED · LIVE</div>\n          <div class=\"up-tc-bar-bg\"><div class=\"up-tc-bar-fill\" style=\"width:100%;background:linear-gradient(90deg,#b464ff,rgba(180,100,255,.4));box-shadow:0 0 4px rgba(180,100,255,.5);\"></div></div>\n        </div>\n      </div>\n\n      <!-- PKG 05 -->\n      \n\n      <!-- PKG 06 -->\n      \n\n      <!-- PKG 07 -->\n      \n\n      <!-- PKG 08 -->\n      \n\n      <!-- PKG 09 -->\n      \n\n      <!-- PKG 10 -->\n      \n\n      <!-- PKG 11 -->\n      <div class=\"up-tc\" style=\"--utc: #00ffb3; position: relative;\">\n        <div class=\"up-tc-head\">\n          <div class=\"up-tc-icon\" style=\"color: rgb(0, 255, 179); border-color: rgba(0, 255, 179, 0.22);\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div>\n          <div class=\"up-tc-meta\">\n            <div class=\"up-tc-title\"><span style=\"font-size: 14.08px;\">COMMENTS AND ACCOUNTS</span></div><div class=\"up-tc-title\"><span style=\"background-color: rgba(0, 255, 179, 0.05); font-size: 0.44rem; letter-spacing: 0.22em;\">BIGGEST FEATURE</span></div></div>\n        </div>\n        <div class=\"up-tc-body\">\n          <div class=\"up-tc-line\">⟡People can now create accounts to comment on chapters</div>\n          <div class=\"up-tc-line\">⟡ Accounts are secured as possible</div></div><div class=\"up-tc-foot\">\n          <div class=\"up-tc-lbl\">DEPLOYED · LIVE</div>\n          <div class=\"up-tc-bar-bg\"><div class=\"up-tc-bar-fill\" style=\"width: 100%; background: linear-gradient(90deg, rgb(0, 255, 179), rgba(0, 255, 179, 0.4)); box-shadow: rgba(0, 255, 179, 0.5) 0px 0px 4px;\"></div></div>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- FOOTER STAMP -->\n    <div style=\"text-align:center;margin-top:3.2rem;padding-top:2rem;border-top:1px solid rgba(0,245,255,.06);position:relative;\">\n      <div style=\"position:absolute;top:0;left:50%;transform:translateX(-50%);width:80px;height:1px;background:linear-gradient(90deg,transparent,var(--c-primary),transparent);\"></div>\n      <div style=\"font-family:'Cinzel',serif;font-size:.52rem;letter-spacing:.48em;color:rgba(0,245,255,.2);margin-bottom:.35rem;\">◈ END OF TRANSMISSION ◈</div>\n      <div style=\"font-family:'Cinzel Decorative',cursive;font-size:.7rem;color:rgba(0,245,255,.18);letter-spacing:.2em;\">MEGAVERDE</div>\n      <div style=\"font-family:'Cinzel',serif;font-size:.44rem;letter-spacing:.28em;color:rgba(0,245,255,.1);margin-top:.3rem;\">VERSION 1.5 · online · BUILT BY TRICKZION</div>\n    </div>\n\n  ",
